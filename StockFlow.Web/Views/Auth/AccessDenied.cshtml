@{
    ViewData["Title"] = "Access denied";
}

<div class="sf-page-header">
    <div>
        <div class="sf-page-title" style="color: var(--sf-danger)">Access denied</div>
        <div class="sf-page-sub">You don't have permission to view this page</div>
    </div>
</div>

<div class="sf-card" style="text-align: center; padding: 48px 24px">
    <div style="font-size: 48px; margin-bottom: 16px">NO</div>
    <div class="sf-page-title" style="margin-bottom: 8px">403 Forbidden</div>
    <p style="color: var(--sf-text-muted); max-width: 400px; margin: 0 auto 24px auto">
        You don't have the required permissions to access this resource. Contact your administrator if you believe this is an error.
    </p>
    <a href="/Dashboard/Index" class="sf-btn sf-btn-primary">Go to Dashboard</a>
</div>
