@model StockFlow.Web.DTOs.Auth.LoginDto
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Sign in — StockFlow</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="~/css/stockflow.css" rel="stylesheet"/>
    <style>
        html, body { height: 100%; margin: 0; font-family: 'Inter', sans-serif; }
        .login-wrap { display: flex; height: 100vh; }
        .login-left {
            flex: 1;
            background: #dbeeff;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px;
            position: relative;
            overflow: hidden;
        }
        .login-left-bg {
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, #c8e4f8 0%, #dbeeff 50%, #eaf5ff 100%);
        }
        .login-left-content { position: relative; z-index: 1; text-align: center; max-width: 360px; }
        .login-logo { display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 40px; }
        .login-logo-icon { width: 40px; height: 40px; background: #1d6fa8; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 600; color: #fff; }
        .login-logo-name { font-size: 20px; font-weight: 600; color: #0f1c2e; }
        .login-illustration { margin-bottom: 32px; }
        .login-tagline { font-size: 22px; font-weight: 600; color: #0f1c2e; line-height: 1.35; margin-bottom: 10px; }
        .login-sub { font-size: 13px; color: #4a6a8a; line-height: 1.6; }
        .login-creds {
            margin-top: 32px;
            background: rgba(255,255,255,0.6);
            border: 0.5px solid rgba(29,111,168,0.2);
            border-radius: 8px;
            padding: 14px 16px;
            text-align: left;
        }
        .login-creds-title { font-size: 10.5px; font-weight: 600; color: #1d6fa8; text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 10px; }
        .cred-row { display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 12px; }
        .cred-row:last-child { margin-bottom: 0; }
        .cred-label { color: #4a6a8a; font-weight: 500; }
        .cred-val { color: #0f1c2e; font-family: monospace; font-size: 11.5px; background: rgba(29,111,168,0.08); padding: 1px 6px; border-radius: 4px; }
        .login-right { width: 440px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px; background: #fff; }
        .login-form-wrap { width: 100%; max-width: 340px; }
        .login-form-title { font-size: 22px; font-weight: 600; color: #0f1c2e; margin-bottom: 4px; }
        .login-form-sub { font-size: 13px; color: #5a6a7a; margin-bottom: 28px; }
        @@media (max-width: 768px) {
            .login-left { display: none; }
            .login-right { width: 100%; }
        }
    </style>
</head>
<body>
<div class="login-wrap">
    <div class="login-left">
        <div class="login-left-bg"></div>
        <div class="login-left-content">
            <div class="login-logo">
                <div class="login-logo-icon">S</div>
                <div class="login-logo-name">StockFlow WMS</div>
            </div>
            <div class="login-illustration">
                <svg width="200" height="160" viewBox="0 0 200 160" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="20" y="80" width="160" height="60" rx="8" fill="#b3d8f5" stroke="#1d6fa8" stroke-width="0.8"/>
                    <rect x="35" y="60" width="130" height="30" rx="6" fill="#cce5f9" stroke="#1d6fa8" stroke-width="0.8"/>
                    <rect x="50" y="44" width="100" height="24" rx="5" fill="#dceefb" stroke="#1d6fa8" stroke-width="0.8"/>
                    <rect x="85" y="110" width="30" height="30" rx="0" fill="#1d6fa8"/>
                    <rect x="40" y="95" width="25" height="14" rx="3" fill="#fff" opacity="0.6"/>
                    <rect x="72" y="95" width="25" height="14" rx="3" fill="#fff" opacity="0.6"/>
                    <rect x="104" y="95" width="25" height="14" rx="3" fill="#fff" opacity="0.6"/>
                    <rect x="136" y="95" width="25" height="14" rx="3" fill="#fff" opacity="0.6"/>
                    <line x1="100" y1="140" x2="100" y2="155" stroke="#1d6fa8" stroke-width="1.5"/>
                    <rect x="60" y="152" width="80" height="6" rx="3" fill="#b3d8f5"/>
                </svg>
            </div>
            <div class="login-tagline">Warehouse management,<br/>simplified.</div>
            <div class="login-sub">Track shipments, process inventory, and manage your warehouse in one place.</div>
            <div class="login-creds">
                <div class="login-creds-title">Demo credentials</div>
                <div class="cred-row"><span class="cred-label">Admin</span><span class="cred-val">admin@stockflow.com / Admin@1234</span></div>
                <div class="cred-row"><span class="cred-label">Manager</span><span class="cred-val">manager@stockflow.com / Manager@1234</span></div>
                <div class="cred-row"><span class="cred-label">Staff</span><span class="cred-val">staff@stockflow.com / Staff@1234</span></div>
            </div>
        </div>
    </div>

    <div class="login-right">
        <div class="login-form-wrap">
            <div class="login-form-title">Welcome back</div>
            <div class="login-form-sub">Sign in to your StockFlow account</div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="sf-alert sf-alert-danger">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <form method="post" action="/Auth/Login" id="login-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]"/>

                <div class="sf-form-group">
                    <label class="sf-label">Email address <span class="required">*</span></label>
                    <input type="email" name="Email" class="sf-input @(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           placeholder="you@company.com" value="@Model?.Email" autocomplete="email" required/>
                    @if (ViewData.ModelState["Email"]?.Errors.Count > 0)
                    {
                        <div class="sf-invalid-feedback">@ViewData.ModelState["Email"]!.Errors[0].ErrorMessage</div>
                    }
                </div>

                <div class="sf-form-group">
                    <label class="sf-label">Password <span class="required">*</span></label>
                    <div class="sf-input-group">
                        <input type="password" name="Password" id="login-password" class="sf-input @(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="Enter your password" autocomplete="current-password" required/>
                        <span class="sf-input-addon" id="toggle-pw" style="cursor:pointer;user-select:none">
                            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M1 8s3-5 7-5 7 5 7 5-3 5-7 5-7-5-7-5z"/><circle cx="8" cy="8" r="2"/>
                            </svg>
                        </span>
                    </div>
                    @if (ViewData.ModelState["Password"]?.Errors.Count > 0)
                    {
                        <div class="sf-invalid-feedback">@ViewData.ModelState["Password"]!.Errors[0].ErrorMessage</div>
                    }
                </div>

                <div class="sf-flex-between sf-mb-12">
                    <label class="sf-flex-center sf-gap-8" style="cursor:pointer;font-size:12.5px;color:var(--sf-text-secondary)">
                        <input type="checkbox" name="RememberMe" value="true" style="accent-color:#1d6fa8"/>
                        Remember me
                    </label>
                </div>

                <button type="submit" class="sf-btn sf-btn-primary sf-btn-lg sf-w-100" id="login-submit">
                    Sign in
                </button>
            </form>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script>
    $('#toggle-pw').on('click', function () {
        var $pw = $('#login-password');
        $pw.attr('type', $pw.attr('type') === 'password' ? 'text' : 'password');
    });
    $('#login-form').on('submit', function () {
        $('#login-submit').text('Signing in...').prop('disabled', true);
    });
</script>
</body>
</html>