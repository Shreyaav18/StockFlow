@using StockFlow.Web.DTOs.Auth
@{
    ViewData["Title"] = "Change password";
    ViewData["Breadcrumb"] = "auth / change password";
}

<div class="sf-page-header">
    <div>
        <div class="sf-page-title">Change password</div>
        <div class="sf-page-sub">Update your password</div>
    </div>
    <a href="/Dashboard/Index" class="sf-btn sf-btn-ghost">← Dashboard</a>
</div>

<div class="sf-card" style="max-width: 500px">
    <form method="post" action="/Auth/ChangePassword">
        @Html.AntiForgeryToken()

        <div class="sf-form-group">
            <label class="sf-label">Current password <span class="required">*</span></label>
            <input type="password" name="CurrentPassword" class="sf-input" placeholder="Enter current password" required/>
        </div>

        <div class="sf-form-group">
            <label class="sf-label">New password <span class="required">*</span></label>
            <input type="password" name="NewPassword" class="sf-input" placeholder="Enter new password (min 8 chars)" required minlength="8"/>
        </div>

        <div class="sf-form-group">
            <label class="sf-label">Confirm new password <span class="required">*</span></label>
            <input type="password" name="ConfirmNewPassword" class="sf-input" placeholder="Re-enter new password" required/>
        </div>

        <button type="submit" class="sf-btn sf-btn-primary">Change password</button>
    </form>
</div>
