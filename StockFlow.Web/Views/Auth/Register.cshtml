@using StockFlow.Web.DTOs.Auth
@{
    ViewData["Title"] = "Register new user";
    ViewData["Breadcrumb"] = "auth / register";
}

<div class="sf-page-header">
    <div>
        <div class="sf-page-title">Register new user</div>
        <div class="sf-page-sub">Create a new account</div>
    </div>
    <a href="/Admin/Users" class="sf-btn sf-btn-ghost">← Back to users</a>
</div>

<div class="sf-card" style="max-width: 600px">
    <form method="post" action="/Auth/Register">
        @Html.AntiForgeryToken()

        <div class="sf-form-group">
            <label class="sf-label">Full name <span class="required">*</span></label>
            <input type="text" name="FullName" class="sf-input" placeholder="Enter full name" required value="@(Model?.FullName ?? "")"/>
        </div>

        <div class="sf-form-group">
            <label class="sf-label">Email <span class="required">*</span></label>
            <input type="email" name="Email" class="sf-input" placeholder="Enter email" required value="@(Model?.Email ?? "")"/>
        </div>

        <div class="sf-form-group">
            <label class="sf-label">Role <span class="required">*</span></label>
            <select name="Role" class="sf-select" required>
                <option value="">— Select role —</option>
                @if (Model?.Role == "Admin")
                {
                    <option value="Admin" selected>Admin</option>
                }
                else
                {
                    <option value="Admin">Admin</option>
                }
                @if (Model?.Role == "Manager")
                {
                    <option value="Manager" selected>Manager</option>
                }
                else
                {
                    <option value="Manager">Manager</option>
                }
                @if (Model?.Role == "Staff")
                {
                    <option value="Staff" selected>Staff</option>
                }
                else
                {
                    <option value="Staff">Staff</option>
                }
            </select>
        </div>

        <div class="sf-form-group">
            <label class="sf-label">Password <span class="required">*</span></label>
            <input type="password" name="Password" class="sf-input" placeholder="Enter password (min 8 chars)" required minlength="8"/>
        </div>

        <div class="sf-form-group">
            <label class="sf-label">Confirm password <span class="required">*</span></label>
            <input type="password" name="ConfirmPassword" class="sf-input" placeholder="Re-enter password" required/>
        </div>

        <button type="submit" class="sf-btn sf-btn-primary">Create user</button>
    </form>
</div>
