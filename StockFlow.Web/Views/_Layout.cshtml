<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <meta name="csrf-token" content="@Antiforgery.GetAndStoreTokens(Context).RequestToken"/>
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — StockFlow" : "StockFlow WMS")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="~/css/stockflow.css" rel="stylesheet"/>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="sf-app">

        <aside class="sf-sidebar" id="sf-sidebar">
            <div class="sf-sidebar-logo">
                <div class="sf-logo-mark">
                    <div class="sf-logo-icon">S</div>
                    <div>
                        <div class="sf-logo-name">StockFlow</div>
                        <div class="sf-logo-sub">WMS v1.0</div>
                    </div>
                </div>
            </div>

            <nav class="sf-sidebar-nav">
                <div class="sf-nav-section">Main</div>
                <a href="/Dashboard" class="sf-nav-item">
                    <svg class="sf-nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="1" y="1" width="6" height="6" rx="1"/><rect x="9" y="1" width="6" height="6" rx="1"/>
                        <rect x="1" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/>
                    </svg>
                    Dashboard
                </a>

                <div class="sf-nav-section">Warehouse</div>
                <a href="/Shipment" class="sf-nav-item">
                    <svg class="sf-nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M2 6l6-4 6 4v8H2V6z"/>
                    </svg>
                    Shipments
                    @if (ViewBag.PendingShipmentCount != null && (int)ViewBag.PendingShipmentCount > 0)
                    {
                        <span class="sf-nav-badge">@ViewBag.PendingShipmentCount</span>
                    }
                </a>
                <a href="/Item" class="sf-nav-item">
                    <svg class="sf-nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="2" y="3" width="12" height="10" rx="1"/><path d="M5 7h6M5 10h4"/>
                    </svg>
                    Items
                </a>
                <a href="/Process" class="sf-nav-item">
                    <svg class="sf-nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                        <circle cx="8" cy="8" r="6"/><path d="M8 5v3l2 2"/>
                    </svg>
                    Processing
                    @if (ViewBag.PendingApprovalCount != null && (int)ViewBag.PendingApprovalCount > 0)
                    {
                        <span class="sf-nav-badge">@ViewBag.PendingApprovalCount</span>
                    }
                </a>

                <div class="sf-nav-section">Analytics</div>
                <a href="/Report" class="sf-nav-item">
                    <svg class="sf-nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M2 12l4-4 3 3 5-6"/>
                    </svg>
                    Reports
                </a>
                <a href="/Search" class="sf-nav-item">
                    <svg class="sf-nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                        <circle cx="6" cy="6" r="4"/><path d="M14 14l-3-3"/>
                    </svg>
                    Search
                </a>

                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                {
                    <div class="sf-nav-section">Admin</div>
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/Users" class="sf-nav-item">
                            <svg class="sf-nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                                <circle cx="8" cy="5" r="3"/><path d="M2 14c0-3 2.7-5 6-5s6 2 6 5"/>
                            </svg>
                            Users
                        </a>
                        <a href="/Admin/AuditLogs" class="sf-nav-item">
                            <svg class="sf-nav-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M2 4h12M2 8h8M2 12h5"/>
                            </svg>
                            Audit Logs
                        </a>
                    }
                }
            </nav>

            <div class="sf-sidebar-user">
                <div class="sf-user-row">
                    <div class="sf-user-avatar">
                        @(User.Identity?.Name?.Length > 0 ? User.Identity.Name.Substring(0,2).ToUpper() : "?")
                    </div>
                    <div>
                        <div class="sf-user-name">@User.Identity?.Name</div>
                        <div class="sf-user-role">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
                    </div>
                </div>
            </div>
        </aside>

        <div class="sf-main">
            <header class="sf-topbar">
                <button class="sf-toggle-btn" id="sf-toggle-btn" type="button">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M1 3h12M1 7h12M1 11h12"/>
                    </svg>
                </button>

                <span class="sf-topbar-title">@(ViewData["Title"] ?? "Dashboard")</span>
                @if (ViewData["Breadcrumb"] != null)
                {
                    <span class="sf-topbar-bread">/ @ViewData["Breadcrumb"]</span>
                }

                <div class="sf-search-wrap" style="margin-left:12px">
                    <svg class="sf-search-icon" width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                        <circle cx="6" cy="6" r="4"/><path d="M14 14l-3-3"/>
                    </svg>
                    <input type="text" id="sf-global-search" class="sf-search-input"
                           placeholder="Search shipments, items..." autocomplete="off"/>
                    <div id="sf-search-dropdown" style="display:none;position:absolute;top:34px;left:0;right:0;background:#fff;border:0.5px solid var(--sf-border);border-radius:var(--sf-radius);z-index:200;box-shadow:0 4px 16px rgba(0,0,0,0.08)"></div>
                </div>

                <div class="sf-topbar-actions">
                    <div class="sf-notif-btn" title="Notifications">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M8 2a4 4 0 014 4v3l1 2H3l1-2V6a4 4 0 014-4z"/>
                            <path d="M6.5 13a1.5 1.5 0 003 0"/>
                        </svg>
                        <div class="sf-notif-dot" style="display:none"></div>
                    </div>
                    <a href="/Shipment/Receive" class="sf-btn sf-btn-primary sf-btn-sm">+ Receive shipment</a>
                    <form method="post" action="/Auth/Logout" style="margin:0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="sf-btn sf-btn-ghost sf-btn-sm">Sign out</button>
                    </form>
                </div>
            </header>

            <main class="sf-content">
                @if (TempData["SuccessMessage"] != null)
                {
                    <input type="hidden" id="sf-temp-success" value="@TempData["SuccessMessage"]"/>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <input type="hidden" id="sf-temp-error" value="@TempData["ErrorMessage"]"/>
                }

                @RenderBody()
            </main>
        </div>
    </div>
}
else
{
    @RenderBody()
}

<div id="sf-toast-container" class="sf-toast-container"></div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/apexcharts@3.49.0/dist/apexcharts.min.js"></script>
<script src="~/js/stockflow.js"></script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>